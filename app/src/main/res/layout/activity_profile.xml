<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.ProfileActivity"
    android:orientation="vertical"
    android:background="@drawable/bg_background_4">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/goBackClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_go_back" />

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginStart="105dp"
            android:layout_marginEnd="90dp"
            app:srcCompat="@drawable/ic_bytequest_logo" />

        <TextView
            android:id="@+id/skipClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textColor="@color/lightGray"
            android:textSize="24dp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="24dp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <ImageView
            android:id="@+id/imageView4"
            android:layout_width="150dp"
            android:layout_height="150dp"
            app:srcCompat="@drawable/ic_profile" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="-125dp"
            android:text="Name"
            android:textSize="16dp"
            android:textColor="@color/lightGray"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/inputFullName"
            android:layout_width="290dp"
            android:layout_height="50dp"
            android:padding="12dp"
            android:ems="10"
            android:inputType="text"
            android:hint=" Full name"
            android:textColor="@color/white"
            android:drawableStart="@drawable/ic_user"
            android:textColorHint="@color/lightGray"
            android:background="@drawable/bg_background_edittext"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="-110dp"
            android:text="Username"
            android:textSize="16dp"
            android:textColor="@color/lightGray"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/inputUsername"
            android:layout_width="290dp"
            android:layout_height="50dp"
            android:padding="12dp"
            android:ems="10"
            android:inputType="text"
            android:hint=" JohnDoe12"
            android:textColor="@color/white"
            android:drawableStart="@drawable/ic_user_2"
            android:textColorHint="@color/lightGray"
            android:background="@drawable/bg_background_edittext"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Gender"
                android:textSize="16dp"
                android:textStyle="bold"/>

            <CheckBox
                android:id="@+id/cbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:paddingRight="36dp"
                android:text="Male"
                android:textColor="#434343"
                android:backgroundTint="@color/purple"
                app:useMaterialThemeColors="true"/>

            <CheckBox
                android:id="@+id/cbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingRight="25dp"
                android:text="Female"
                android:textColor="#434343"
                android:backgroundTint="@color/purple"
                app:useMaterialThemeColors="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Birth date"
                android:textSize="16dp"
                android:textStyle="bold"/>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/transparentLightGray"
                app:cardCornerRadius="10dp">

                <LinearLayout
                    android:id="@+id/dateOfBirthPicker"
                    android:onClick="openDatePickerDialog"
                    android:layout_width="205dp"
                    android:layout_height="match_parent"
                    android:paddingRight="12dp"
                    android:paddingLeft="12dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/transparentLightGray">

                    <ImageView
                        android:id="@+id/imageView3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="5dp"
                        app:srcCompat="@drawable/ic_calendar" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Calendar" />

                        <TextView
                            android:id="@+id/inputDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/19/2005"
                            android:textSize="18dp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="-115dp"
            android:text="Address"
            android:textSize="16dp"
            android:textColor="@color/lightGray"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">

            <EditText
                android:id="@+id/inputAddress"
                android:layout_width="290dp"
                android:layout_height="50dp"
                android:padding="12dp"
                android:ems="10"
                android:inputType="text"
                android:textColor="@color/white"
                android:hint="123 Main Street Springfield, IL 62704 USA"
                android:drawableStart="@drawable/ic_location"
                android:textColorHint="@color/lightGray"
                android:background="@drawable/bg_background_edittext"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center">

        <Button
            android:id="@+id/saveProfileBtn"
            android:layout_width="234dp"
            android:layout_height="60dp"
            android:textSize="20dp"
            android:text="Save"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/purple" />
    </LinearLayout>
</LinearLayout>