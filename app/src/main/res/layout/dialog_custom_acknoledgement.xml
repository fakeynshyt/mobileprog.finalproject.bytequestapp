<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/acknowledgementConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    android:layout_marginHorizontal="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_background_acknowledgement">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="90dp"
            android:layout_marginTop="18dp"
            android:src="@drawable/img_dialog_image2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Congratiolations!"
            android:textSize="32dp"
            android:textStyle="bold"
            android:textColor="#FFEB3B"/>

        <TextView
            android:id="@+id/displayRewardTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.5dp"
            android:textAlignment="center"
            android:text="You’ve received 50 Byte points\nfor joining ByteQuest!"
            android:textSize="18dp"
            android:textColor="@color/darkModePrimaryColor"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/claimRewardBtn"
            android:layout_width="200dp"
            android:layout_height="55dp"
            android:layout_marginTop="12.5dp"
            android:layout_marginBottom="18dp"
            android:text="Claim"
            android:textSize="24dp"
            android:elevation="0dp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_custom_botton"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>