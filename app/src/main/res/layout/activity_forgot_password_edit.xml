<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activities.ForgotPasswordEditActivity"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_background_8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    app:srcCompat="@drawable/ic_bytequest_logo_alt"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="55dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:text="Reset Password"
                android:textSize="38dp"
                android:textStyle="bold"
                android:textColor="@color/purple"/>

            <TextView
                android:layout_width="232dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:text="Resetting your password lets you create a new one if you’ve forgotten or lost access."
                android:textSize="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your new password"
                android:textSize="16dp"
                android:textColor="@color/darkGray"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/inputNewPass"
                android:layout_width="350dp"
                android:layout_height="50dp"
                android:padding="12dp"
                android:ems="10"
                android:inputType="textPassword"
                android:textColor="@color/white"
                android:drawableStart="@drawable/ic_password"
                android:background="@drawable/bg_background_edittext"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Confirm your password"
                android:textSize="16dp"
                android:textColor="@color/darkGray"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/inputConfirmPass"
                android:layout_width="350dp"
                android:layout_height="50dp"
                android:padding="12dp"
                android:ems="10"
                android:inputType="textPassword"
                android:textColor="@color/white"
                android:drawableStart="@drawable/ic_confirm_pass"
                android:background="@drawable/bg_background_edittext"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="350dp"
                android:layout_height="60dp"
                android:backgroundTint="@color/purple"
                android:text="Continue"
                android:textSize="20dp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="350dp"
                android:layout_height="60dp"
                android:textSize="20dp"
                android:text="Cancel"
                android:textStyle="bold"
                android:textColor="@color/purple"
                android:backgroundTint="@color/white"
                app:strokeColor="@color/purple"
                app:strokeWidth="2dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>